{
  "name": "meme-farm",
  "version": "0.2.0",
  "description": "A chaotic vanilla JS idle clicker about building an absurd meme empire.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node scripts/dev-server.cjs",
    "dev": "node scripts/dev-server.cjs",
    "check": "node scripts/smoke-check.cjs",
    "build": "npm run check",
    "electron": "electron .",
    "package:electron": "electron-builder"
  },
  "build": {
    "appId": "com.memefarm.game",
    "productName": "Meme Farm",
    "files": [
      "src/**/*",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/steamworks-ffi-node/**/*",
      "node_modules/koffi/**/*"
    ],
    "extraResources": [
      {
        "from": "steamworks_sdk/redistributable_bin",
        "to": "steamworks_sdk/redistributable_bin"
      }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "steamworks-ffi-node": "^0.10.4"
  }
}
