{
  "name": "meme-farm",
  "version": "0.2.0",
  "description": "A chaotic vanilla JS idle clicker about building an absurd meme empire.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node scripts/dev-server.cjs",
    "dev": "node scripts/dev-server.cjs",
    "check": "node scripts/smoke-check.cjs",
    "build": "npm run check",
    "electron": "electron .",
    "package:electron": "electron-builder"
  },
  "build": {
    "appId": "com.memefarm.game",
    "productName": "Meme Farm",
    "files": [
      "src/**/*",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
